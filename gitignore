# ----------------------------------------------------------------------------
# Analysis outputs (large files; regenerate by running run_all.R)
# ----------------------------------------------------------------------------
GSE160299_DESeq2_analysis/
*_DESeq2_analysis/

# ----------------------------------------------------------------------------
# Downloaded GEO data (re-downloadable; often large)
# ----------------------------------------------------------------------------
data_raw/
*.tar
*.tar.gz
*.soft.gz
*_series_matrix.txt.gz

# ----------------------------------------------------------------------------
# R session artifacts
# ----------------------------------------------------------------------------
.Rhistory
.RData
.Rapp.history
.Rproj.user/
*.Rproj

# R package build artifacts
*.o
*.so
*.dll
src/*.o
src/*.so

# ----------------------------------------------------------------------------
# renv / packrat (lock files are OK to commit; the library itself is not)
# ----------------------------------------------------------------------------
renv/library/
renv/python/
renv/staging/
packrat/lib/
packrat/lib-ext/
packrat/lib-R/
packrat/bundles/

# It's fine to track renv.lock and packrat/packrat.lock:
!renv.lock
!packrat/packrat.lock

